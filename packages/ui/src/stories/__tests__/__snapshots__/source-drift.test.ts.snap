{
  "html": "<section class="w-full" style="background-color:color-mix(in srgb, var(--color-accent) 6%, var(--color-bg));" aria-label="Hero"><div class="max-w-[88rem] py-vsp-2xl" style="margin-inline:auto;padding-inline:clamp(var(--spacing-hsp-md), 4vw, var(--spacing-hsp-2xl));"><p class="text-caption font-semibold uppercase tracking-wide text-accent">Sample Co.</p><h1 class="mt-vsp-sm max-w-[20ch] font-bold leading-tight text-fg" style="font-size:clamp(var(--text-display), 1.6rem + 3.4vw, 4rem);text-wrap:balance;">Build things that last</h1><p class="mt-vsp-md max-w-[44rem] text-title leading-relaxed text-fg" style="text-wrap:pretty;">A demo company combining two imaginary product lines into one storefront.</p><div class="mt-vsp-lg flex flex-wrap gap-x-hsp-md gap-y-vsp-xs"><a href="/products" class="inline-flex items-center gap-x-hsp-xs rounded-md px-hsp-xl py-vsp-sm text-small font-semibold no-underline transition-colors bg-accent text-bg hover:bg-accent-hover border border-accent hover:border-accent-hover" style="text-decoration:none;color:var(--color-bg);"><span data-cta-label="true">Browse products</span><span aria-hidden="true">→</span></a><a href="/company" class="inline-flex items-center gap-x-hsp-xs rounded-md px-hsp-xl py-vsp-sm text-small font-semibold no-underline transition-colors bg-bg text-accent border border-border hover:border-accent hover:bg-surface" style="text-decoration:none;color:var(--color-accent);"><span data-cta-label="true">About us</span><span aria-hidden="true">→</span></a></div></div></section>",
