tion-colors outline-none focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus disabled:opacity-50 disabled:cursor-not-allowed aria-disabled:opacity-50 text-sm px-hsp-lg py-vsp-2xs bg-brand text-on-brand hover:bg-brand-strong active:bg-brand-strong">Send message</button></div></form>",
  "source": "<form class="flex max-w-[28rem] flex-col gap-vsp-md" onSubmit={…}>
