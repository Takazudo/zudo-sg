{
  "html": "<div style="max-width:760px;"><section class="flex flex-col gap-y-vsp-md" aria-label="Recruiting entry form" data-recruit-form="true"><div class="flex flex-col gap-y-vsp-2xs"><h2 class="text-heading font-bold leading-tight text-fg">Entry form</h2><p class="max-w-[44rem] text-caption leading-relaxed text-muted">Fill in and submit the form below. Our recruiting team will review it and email you with next steps. Fields marked <span class="text-accent">Required</span> must be filled in.</p></div><div data-recruit-panel="input"><form data-recruit-form-el="true" class="flex flex-col gap-y-vsp-md rounded-md border border-border bg-surface px-hsp-lg py-vsp-md" novalidate><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-category" class="text-caption font-semibold text-fg">Recruiting category<span class="ms-hsp-2xs align-middle text-micro font-medium text-accent">Required</span></label><span class="relative block"><select class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent appearance-none pe-hsp-xl" id="recruit-category" name="category" required><option value="new-graduate">New graduate</option><option selected value="career">Career (mid-career)</option></select><span class="pointer-events-none absolute end-hsp-md top-1/2 -translate-y-1/2 text-micro text-muted" aria-hidden="true">▾</span></span></div><div class="grid grid-cols-1 gap-hsp-md sm:grid-cols-2"><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-name" class="text-caption font-semibold text-fg">Name<span class="ms-hsp-2xs align-middle text-micro font-medium text-accent">Required</span></label><input type="text" class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent" id="recruit-name" name="name" autocomplete="name" required/></div><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-kana" class="text-caption font-semibold text-fg">Name (phonetic)<span class="ms-hsp-2xs align-middle text-micro font-medium text-accent">Required</span></label><input type="text" class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent" id="recruit-kana" name="kana" required/></div></div><div class="grid grid-cols-1 gap-hsp-md sm:grid-cols-2"><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-email" class="text-caption font-semibold text-fg">Email<span class="ms-hsp-2xs align-middle text-micro font-medium text-accent">Required</span></label><p id="recruit-email-hint" class="text-micro leading-snug text-muted">Used for interview/next-step scheduling.</p><input type="email" class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent" id="recruit-email" name="email" autocomplete="email" required aria-describedby="recruit-email-hint"/></div><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-phone" class="text-caption font-semibold text-fg">Phone number<span class="ms-hsp-2xs align-middle text-micro font-medium text-accent">Required</span></label><p id="recruit-phone-hint" class="text-micro leading-snug text-muted">A number you can be reached at during business hours.</p><input type="tel" class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent" id="recruit-phone" name="phone" autocomplete="tel" required aria-describedby="recruit-phone-hint"/></div></div><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-affiliation" class="text-caption font-semibold text-fg">Affiliation (school / current employer)<span class="ms-hsp-2xs align-middle text-micro font-normal text-muted">Optional</span></label><p id="recruit-affiliation-hint" class="text-micro leading-snug text-muted">New graduates: school and department. Career: current employer.</p><input type="text" class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent" id="recruit-affiliation" name="affiliation" autocomplete="organization" aria-describedby="recruit-affiliation-hint"/></div><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-job" class="text-caption font-semibold text-fg">Desired role<span class="ms-hsp-2xs align-middle text-micro font-medium text-accent">Required</span></label><span class="relative block"><select class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent appearance-none pe-hsp-xl" id="recruit-job" name="job" required><option value="sales">Sales</option><option value="engineer">Engineer (FAE / FSE)</option><option value="research">Research</option><option value="corporate">Corporate (finance, HR, legal, etc.)</option><option value="undecided">Not yet decided / would like to discuss</option></select><span class="pointer-events-none absolute end-hsp-md top-1/2 -translate-y-1/2 text-micro text-muted" aria-hidden="true">▾</span></span></div><div class="flex flex-col gap-y-vsp-2xs"><label for="recruit-message" class="text-caption font-semibold text-fg">Self-introduction / questions<span class="ms-hsp-2xs align-middle text-micro font-normal text-muted">Optional</span></label><p id="recruit-message-hint" class="text-micro leading-snug text-muted">Feel free to share your motivation, experience, or any questions.</p><textarea rows="6" class="w-full rounded-md border border-border bg-bg px-hsp-md py-vsp-xs text-small text-fg transition-colors focus-visible:border-accent focus-visible:outline focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent resize-y" id="recruit-message" name="message" aria-describedby="recruit-message-hint"></textarea></div><div class="flex flex-col gap-y-vsp-xs"><p class="text-micro leading-snug text-muted">Personal information you provide is used solely for recruiting-related communication.</p><button type="submit" class="inline-flex items-center justify-center gap-x-hsp-xs rounded-md border border-accent bg-accent px-hsp-xl py-vsp-xs text-small font-semibold text-bg cursor-pointer transition-colors hover:border-accent-hover hover:bg-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-50 self-start">Review my entry</button></div></form></div><div data-recruit-panel="confirm" hidden><div class="flex flex-col gap-y-vsp-md rounded-md border border-border bg-surface px-hsp-lg py-vsp-md"><div class="flex flex-col gap-y-vsp-2xs"><h3 class="text-title font-semibold text-fg">Confirm your entry</h3><p class="text-caption leading-relaxed text-muted">Review the details below before sending. Use &quot;Back to edit&quot; to make changes.</p></div><dl class="flex flex-col gap-y-vsp-sm"><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Recruiting category</dt><dd class="text-small text-fg" data-recruit-review="category"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Name</dt><dd class="text-small text-fg" data-recruit-review="name"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Name (phonetic)</dt><dd class="text-small text-fg" data-recruit-review="kana"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Email</dt><dd class="text-small text-fg" data-recruit-review="email"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Phone number</dt><dd class="text-small text-fg" data-recruit-review="phone"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Affiliation</dt><dd class="text-small text-fg" data-recruit-review="affiliation"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Desired role</dt><dd class="text-small text-fg" data-recruit-review="job"></dd></div><div class="grid grid-cols-1 gap-y-vsp-2xs border-b border-border pb-vsp-sm sm:grid-cols-[12rem_1fr] sm:gap-x-hsp-md"><dt class="text-caption font-semibold text-muted">Self-introduction / questions</dt><dd class="text-small text-fg whitespace-pre-wrap" data-recruit-review="message"></dd></div></dl><div class="flex flex-wrap gap-x-hsp-md gap-y-vsp-xs"><button type="button" class="inline-flex cursor-pointer items-center justify-center rounded-md border border-border bg-bg px-hsp-lg py-vsp-xs text-small font-medium text-fg transition-colors hover:border-accent hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-50" data-recruit-action="edit">Back to edit</button><button type="button" class="inline-flex items-center justify-center gap-x-hsp-xs rounded-md border border-accent bg-accent px-hsp-xl py-vsp-xs text-small font-semibold text-bg cursor-pointer transition-colors hover:border-accent-hover hover:bg-accent-hover focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-50" data-recruit-action="send">Submit this entry</button></div></div></div><div data-recruit-panel="complete" hidden><div class="flex flex-col gap-y-vsp-sm rounded-md border border-border border-l-4 px-hsp-lg py-vsp-md" style="border-left-color:var(--color-accent);background-color:color-mix(in srgb, var(--color-accent) 8%, var(--color-bg));" role="status"><h3 class="text-title font-semibold text-accent">Your entry has been received</h3><p class="text-small leading-relaxed text-fg">We've received your entry. Our recruiting team will follow up at the email address you provided with details on next steps. Thank you for applying.</p><button type="button" class="inline-flex cursor-pointer items-center justify-center rounded-md border border-border bg-bg px-hsp-lg py-vsp-xs text-small font-medium text-fg transition-colors hover:border-accent hover:text-accent focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-50 self-start" data-recruit-action="reset">Start another entry</button></div></div></section></div>",
  "source": "<RecruitEntryForm defaultCategory="career" />",
}
`;

