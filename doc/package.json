{
  "name": "@zudo-sg/doc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "zfb dev",
    "prebuild": "pnpm gen:doc-history-meta",
    "build": "zfb build",
    "preview": "zfb preview",
    "precheck": "pnpm gen:doc-history-meta",
    "check": "zfb check",
    "check:html": "html-validate \"dist/**/*.html\"",
    "gen:doc-history-meta": "node -e \"const fs = require('node:fs'); fs.mkdirSync('.zfb', { recursive: true }); fs.writeFileSync('.zfb/doc-history-meta.json', '{}\\\\n');\"",
    "gen:z-index": "gen-z-index",
    "check:z-index": "gen-z-index --check",
    "setup:doc-skill": "bash scripts/setup-doc-skill.sh",
    "setup:doc-skill-silent": "bash scripts/setup-doc-skill.sh --silent",
    "setup:doc-skill:claude": "bash scripts/setup-doc-skill.sh --target claude",
    "setup:doc-skill:codex": "bash scripts/setup-doc-skill.sh --target codex",
    "setup:doc-skill:both": "bash scripts/setup-doc-skill.sh --target both"
  },
  "dependencies": {
    "@takazudo/zfb": "0.1.0-next.89",
    "@takazudo/zfb-runtime": "0.1.0-next.89",
    "@takazudo/zfb-adapter-cloudflare": "0.1.0-next.89",
    "@takazudo/zfb-md-wasm": "0.1.0-next.89",
    "@takazudo/zudo-doc": "4.3.0",
    "@takazudo/zudo-doc-history-server": "^4.3.0",
    "zod": "^4.3.6",
    "preact": "^10.29.7",
    "preact-render-to-string": "^6.6.6",
    "gray-matter": "^4.0.0",
    "mermaid": "^11.12.3",
    "remark-cjk-friendly": "^2.0.1",
    "remark-directive": "^3.0.0",
    "katex": "^0.16.38",
    "diff": "^8.0.3",
    "minisearch": "^7.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "html-validate": "^10.0.0",
    "pagefind": "^1.4.0"
  }
}
