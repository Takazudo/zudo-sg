{
  "name": "zudo-sg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "zfb dev",
    "build": "zfb build",
    "preview": "zfb preview",
    "check": "zfb check && pnpm --filter @zudo-sg/ui typecheck && pnpm --filter @zudo-sg/demo typecheck && pnpm --filter @zudo-sg/doc check",
    "check:html": "html-validate \"dist/**/*.html\"",
    "check:links": "node scripts/check-links.mjs",
    "check:links:demo": "node scripts/check-links.mjs --dist=apps/demo/dist",
    "check:links:doc": "node scripts/check-links.mjs --dist=doc/dist",
    "build:doc": "pnpm --filter @zudo-sg/doc build",
    "gen:z-index": "node scripts/gen-z-index.mjs",
    "check:z-index": "node scripts/gen-z-index.mjs --check",
    "gen:sg-registry": "node scripts/gen-sg-registry.mjs",
    "check:sg-registry": "node scripts/gen-sg-registry.mjs --check",
    "gen:story-categories": "node scripts/gen-story-categories.mjs",
    "check:story-categories": "node scripts/gen-story-categories.mjs --check",
    "new:component": "node scripts/new-component.mjs",
    "gen:token-manifest": "node scripts/gen-token-manifest.mjs",
    "check:token-manifest": "node scripts/gen-token-manifest.mjs --check",
    "gen:root-token-manifest": "node scripts/gen-root-token-manifest.mjs",
    "check:root-token-manifest": "node scripts/gen-root-token-manifest.mjs --check",
    "contrast:audit": "tsx scripts/contrast-audit.ts",
    "lint:tokens": "node $(realpath node_modules/@takazudo/zudo-design-token-lint/dist/cli.js)",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "test:e2e:composer-reuse": "playwright test --config=playwright.composer-verification.config.ts --project=composer-reuse",
    "test:e2e:composer-persistence": "playwright test --config=playwright.composer-persistence.config.ts --project=composer-persistence --project=composer-production-boundary --project=composer-adapted",
    "test:e2e:composer-verification": "playwright test --config=playwright.composer-verification.config.ts",
    "test:e2e:composer-file": "playwright test --config=playwright.composer-file.config.ts",
    "test:e2e:prose-window-blur": "bash scripts/run-prose-window-blur.sh",
    "b4push": "bash scripts/run-b4push.sh",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-css": "^6.0.0",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@takazudo/zdtp": "0.4.9",
    "@takazudo/zfb": "0.1.0-next.89",
    "@takazudo/zfb-adapter-cloudflare": "0.1.0-next.89",
    "@takazudo/zfb-md-wasm": "0.1.0-next.89",
    "@takazudo/zfb-runtime": "0.1.0-next.89",
    "@takazudo/zudo-doc": "4.3.0",
    "@takazudo/zudo-doc-history-server": "^4.3.0",
    "@zudo-sg/ui": "workspace:*",
    "diff": "^8.0.4",
    "gray-matter": "^4.0.0",
    "katex": "^0.16.38",
    "mermaid": "^11.12.3",
    "minisearch": "^7.2.0",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.6",
    "remark-cjk-friendly": "^2.0.1",
    "remark-directive": "^3.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.2.0",
    "@takazudo/zudo-design-token-lint": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/culori": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "culori": "^4.0.2",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^16.8.1",
    "html-validate": "^10.0.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "msw": "^2.15.0",
    "postcss": "^8.5.21",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
