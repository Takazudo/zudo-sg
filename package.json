{
  "name": "zudo-sg",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "zfb dev",
    "build": "zfb build",
    "preview": "zfb preview",
    "check": "zfb check && pnpm --filter @zudo-sg/ui typecheck",
    "check:html": "html-validate \"dist/**/*.html\"",
    "check:links": "node scripts/check-links.mjs",
    "gen:z-index": "node scripts/gen-z-index.mjs",
    "check:z-index": "node scripts/gen-z-index.mjs --check",
    "gen:token-manifest": "node scripts/gen-token-manifest.mjs",
    "check:token-manifest": "node scripts/gen-token-manifest.mjs --check",
    "setup:doc-skill": "bash scripts/setup-doc-skill.sh",
    "lint:tokens": "node $(realpath node_modules/@takazudo/zudo-design-token-lint/dist/cli.js)",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --reporter=list",
    "b4push": "bash scripts/run-b4push.sh",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-css": "^6.0.0",
    "@codemirror/lang-javascript": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@shikijs/transformers": "^4.0.0",
    "@takazudo/zdtp": "0.4.3",
    "@takazudo/zfb": "0.1.0-next.76",
    "@takazudo/zfb-adapter-cloudflare": "0.1.0-next.76",
    "@takazudo/zfb-runtime": "0.1.0-next.76",
    "@takazudo/zudo-doc": "2.5.1",
    "@zudo-sg/ui": "workspace:*",
    "gray-matter": "^4.0.0",
    "katex": "^0.16.38",
    "mermaid": "^11.12.3",
    "minisearch": "^7.2.0",
    "preact": "^10.29.1",
    "preact-render-to-string": "^6.6.6",
    "remark-cjk-friendly": "^2.0.1",
    "remark-directive": "^3.0.0",
    "shiki": "^4.0.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.2.0",
    "@takazudo/zudo-design-token-lint": "^1.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "happy-dom": "^16.8.1",
    "html-validate": "^10.0.0",
    "lefthook": "^2.1.9",
    "pagefind": "^1.4.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  }
}
